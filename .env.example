# Copia este archivo como ".env" y llena tus valores reales.
# El archivo ".env" NUNCA se sube a git (ya está en .gitignore).

# --- Conexión a PostgreSQL (Neon / Supabase free tier) ---
DATABASE_URL=postgresql://usuario:password@host:5432/nombre_db

# --- Zona activa para V1 ---
# Se define en Fase 1b, luego de comparar Hoboken vs Jersey City.
ACTIVE_CITY=

# --- Parámetros de negocio (ajustables) ---
LEAD_TIME_HOURS=2
SERVICE_LEVEL_Z=1.65
